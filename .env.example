# ─── Supabase ────────────────────────────────────────────────────────────────
# Clave pública (anon) — puede estar en el cliente con RLS activa
NEXT_PUBLIC_SUPABASE_URL=https://<tu-proyecto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<tu-clave-anon-publica>

# Clave privada — SOLO server-side, NUNCA prefijo NEXT_PUBLIC_
# Usada en route handlers (app/api/*) para operaciones que bypasean RLS
SUPABASE_SERVICE_ROLE_KEY=<tu-clave-service-role>

# ─── Contacto / Notificaciones ───────────────────────────────────────────────
# Email destino para notificaciones de nuevos mensajes de contacto
ADMIN_EMAIL=admin@ejemplo.com

# ─── Pagos (Stripe) — TODO: configurar cuando esté disponible ────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Analítica — TODO: configurar cuando esté disponible ─────────────────────
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=deportesinfronteras.org
# NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://analytics.tudominio.com/script.js
